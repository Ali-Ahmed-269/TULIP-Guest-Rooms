RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Deny access to config and uploads/payments via Apache rules
<IfModule mod_authz_core.c>
    <Directory "${DOCUMENT_ROOT}/config">
        Require all denied
    </Directory>
    <Directory "${DOCUMENT_ROOT}/uploads/payments">
        Require all denied
    </Directory>
</IfModule>
RewriteEngine On

# Enforce HTTPS redirect
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to config/ and uploads/payments/ directories
RewriteRule ^config/ - [F,L]
RewriteRule ^uploads/payments/ - [F,L]
